# MyWebDrive env sample (development)
# Copy as .env and adjust values as needed.

# --- Core Security ---
# Required: used by all services for JWT signing/verification
JWT_SECRET=dev_super_secret_change_me

# --- Database ---
# Shared SQLite DB path used by gateway/auth/user/storage/sharing/metadata in dev
DATABASE_PATH=./data/mywebdrive.db

# --- API Gateway service discovery ---
# Downstream service URLs that the API Gateway proxies to
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
METADATA_SERVICE_URL=http://localhost:8083
STORAGE_SERVICE_URL=http://localhost:8084
SHARING_SERVICE_URL=http://localhost:8085

# --- Storage backend (choose local path or MinIO) ---
# Local filesystem storage (default)
STORAGE_PATH=./storage

# MinIO (set USE_MINIO=true to enable)
USE_MINIO=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=mywebdrive

# --- Registration & invites ---
REGISTRATION_REQUIRE_INVITE=true
INVITE_CODE_LENGTH=16
INVITE_DEFAULT_USAGE_LIMIT=1
# Go duration syntax, e.g. 168h = 7 days
INVITE_DEFAULT_TTL=168h

# --- User defaults ---
USER_DEFAULT_QUOTA_GB=5

# --- Password hashing & token durations ---
BCRYPT_COST=10
# Go duration syntax
ACCESS_TOKEN_DURATION=2h
REFRESH_TOKEN_DURATION=720h

# --- CORS ---
# Comma-separated origins. For Vite dev server use:
# CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=*

# --- Optional config file path override ---
# If provided, some services read defaults from a YAML file
# CONFIG_PATH=backend/config/config.yaml

# --- Next.js (dev server as BFF) ---
# Next will proxy /api/v1 to this base URL (Node gateway default :9080)
# API_BASE_URL=http://localhost:9080

# --- Health & Admin ---
# Health endpoints are available at each service root: /health
# Admin overview (JWT admin required) via API Gateway: /api/v1/admin/overview
