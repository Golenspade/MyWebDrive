# MyWebDrive env example (Node, SoR-aligned)
# Copy as .env and adjust values as needed.

# --- Core Security ---
JWT_SECRET=dev_super_secret_change_me

# --- Ports (gateway + services) ---
GATEWAY_PORT=9080
AUTH_PORT=7081
USER_PORT=7082
METADATA_PORT=7083
STORAGE_PORT=7084
SHARING_PORT=7085

# --- Frontend (cruip-landing Next) ---
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3100
API_BASE_URL=http://localhost:9080

# --- Service URLs (Gateway -> Downstream) ---
AUTH_SERVICE_URL=http://localhost:7081
USER_SERVICE_URL=http://localhost:7082
METADATA_SERVICE_URL=http://localhost:7083
STORAGE_SERVICE_URL=http://localhost:7084
SHARING_SERVICE_URL=http://localhost:7085

# --- CORS ---
# Comma-separated origins, e.g. http://127.0.0.1:3100
CORS_ALLOWED_ORIGINS=*

# --- Redis (used by storage) ---
REDIS_URL=redis://localhost:6379/0

# --- Storage backend (local path or MinIO) ---
STORAGE_PATH=./storage
USE_MINIO=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=mywebdrive

# --- Database URLs ---
# For Metadata/Storage/Sharing we use service-specific env vars (read directly by Prisma):
METADATA_DATABASE_URL=file:./services/metadata/prisma/metadata.db
STORAGE_DATABASE_URL=file:./services/storage/prisma/storage.db
SHARING_DATABASE_URL=file:./services/sharing/prisma/sharing.db

# For Auth/User Prisma, the schema expects env("DATABASE_URL"). Do NOT set a global
# DATABASE_URL in this .env (it would affect both services). Instead, pass inline per command, e.g.:
#   DATABASE_URL="file:./services/auth/prisma/auth.db" pnpm -C services/auth db:push --accept-data-loss
#   DATABASE_URL="file:./services/user/prisma/user.db" pnpm -C services/user db:push --accept-data-loss
# Or export and run one service per shell process.

# --- Token TTLs (seconds) ---
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# --- Invitation code settings ---
# Require invitation code during registration when set to true
REGISTRATION_REQUIRE_INVITE=false
# Default usage limit for generated invitation codes
INVITE_DEFAULT_USAGE_LIMIT=10
# Default invitation expiration in seconds (30 days)
INVITE_DEFAULT_TTL_SEC=2592000
# Length of generated invitation codes
INVITE_CODE_LENGTH=16

# --- Owner cookie for storage admin endpoints (if any) ---
OWNER_COOKIE_SECRET=please-change-me
OWNER_COOKIE_TTL_SEC=86400
COOKIE_SECURE=false
# Generate hash via: node -e "console.log(require('bcryptjs').hashSync('your-owner-code', 10))"
OWNER_CODE_HASH=
