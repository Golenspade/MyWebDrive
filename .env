# MyWebDrive env sample (development)
# Copy as .env and adjust values as needed.

# --- Core Security ---
# Required: used by all services for JWT signing/verification
JWT_SECRET=please-change-me

# --- Database ---
# Shared SQLite DB path used by gateway/auth/user/storage/sharing/metadata in dev
DATABASE_PATH=./data/mywebdrive.db

# --- API Gateway service discovery ---
# Downstream service URLs that the API Gateway proxies to
AUTH_SERVICE_URL=http://localhost:7091
USER_SERVICE_URL=http://localhost:7092
METADATA_SERVICE_URL=http://localhost:7093
STORAGE_SERVICE_URL=http://localhost:7094
SHARING_SERVICE_URL=http://localhost:7095

# --- Frontend (cruip-landing Next) ---
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3100
API_BASE_URL=http://localhost:9090

# --- Storage backend (choose local path or MinIO) ---
# Local filesystem storage (default)
STORAGE_PATH=./storage

# MinIO (set USE_MINIO=true to enable)
USE_MINIO=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=mywebdrive

# --- Registration & invites ---
REGISTRATION_REQUIRE_INVITE=true
INVITE_CODE_LENGTH=16
INVITE_DEFAULT_USAGE_LIMIT=1
# Go duration syntax, e.g. 168h = 7 days
INVITE_DEFAULT_TTL=168h

# --- User defaults ---
USER_DEFAULT_QUOTA_GB=5

# --- Password hashing & token durations ---
BCRYPT_COST=10
# Go duration syntax
ACCESS_TOKEN_DURATION=2h
REFRESH_TOKEN_DURATION=720h

# --- CORS ---
# Comma-separated origins. 本地 Next 前端可使用:
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:3100
CORS_ALLOWED_ORIGINS=*

# --- Optional config file path override ---
# If provided, some services read defaults from a YAML file
# CONFIG_PATH=backend/config/config.yaml

# --- Node service ports ---
# API Gateway (Node)
GATEWAY_PORT=9090

# Individual service ports (7091-7095 to avoid conflicts)
AUTH_PORT=7091
USER_PORT=7092
METADATA_PORT=7093
STORAGE_PORT=7094
SHARING_PORT=7095

# Per-service Postgres URLs (single DB with separate schemas)
# Matches docker Postgres container: user=postgres, password=postgres, db=postgres
AUTH_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=auth"
USER_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=user"
METADATA_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=metadata"
STORAGE_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=storage"
SHARING_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=sharing"
GATEWAY_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=gateway"


# Storage dev flags
STORAGE_SKIP_METADATA=false

# --- Health & Admin ---
# Health endpoints are available at each service root: /health
# Admin overview (JWT admin required) via API Gateway: /api/v1/admin/overview
