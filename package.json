{
  "name": "mywebdrive",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "build:all": "pnpm -r --filter ./packages/** --filter ./services/** --filter ./apps/** build",
    "typecheck": "tsc -b --pretty false",
    "clean": "pnpm -r run clean || true",
    "dev": "pnpm -C frontend/cruip-landing dev"
  },
  "devDependencies": {
    "eslint-plugin-react-refresh": "^0.4.24"
  }
}
