# Core auth
JWT_SECRET=dev-secret-change-me

# Service ports (Node)
GATEWAY_PORT=9080
AUTH_PORT=7081
USER_PORT=7082
METADATA_PORT=7083
STORAGE_PORT=7084
SHARING_PORT=7085

# Downstream service URLs (used by API Gateway)
AUTH_SERVICE_URL=http://localhost:7081
USER_SERVICE_URL=http://localhost:7082
METADATA_SERVICE_URL=http://localhost:7083
STORAGE_SERVICE_URL=http://localhost:7084
SHARING_SERVICE_URL=http://localhost:7085

# Logging
LOG_LEVEL=info
# Optional: set a custom instance label in logs/metrics
# INSTANCE_ID=

# Storage (local or MinIO)
STORAGE_PATH=./storage
USE_MINIO=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_USE_SSL=false
MINIO_BUCKET=mywebdrive
# Optional: compute MD5 in worker to offload event loop (true/false)
MD5_IN_WORKER=false

# Auth/Invitations (dev defaults)
REGISTRATION_REQUIRE_INVITE=false
INVITE_DEFAULT_USAGE_LIMIT=1
INVITE_CODE_LENGTH=16
INVITE_DEFAULT_TTL_SEC=2592000

# manage-services.sh toggles to run Node replacements for Go services
USE_NODE_METADATA=true
USE_NODE_STORAGE=true
USE_NODE_SHARING=true
