{
  "name": "sharing-service-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b && prisma generate",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "@prisma/client": "^5.19.1",
    "prom-client": "^15.1.3",
    "@mywebdrive/common": "workspace:*",
    "@mywebdrive/observability": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.17.0",
    "rimraf": "^5.0.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "prisma": "^7.0.1"
  }
}
