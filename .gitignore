# Monorepo ignores
node_modules/
**/node_modules/

# Environment files
.env
.env.*
!.env.example
!docs/env.example

# Logs
logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs / caches
**/.tsbuildinfo
packages/*/dist/
services/*/dist/
apps/*/dist/

# Framework outputs
apps/*/.next/
apps/*/out/
frontend/cruip-landing/.next/
frontend/cruip-landing/out/

# Prisma generated clients and dev DBs
services/*/prisma/client/
services/*/prisma/*.db

# Coverage
coverage/
.nyc_output/

# OS / editors
.DS_Store
.idea/
.vscode/




# Runtime storage payloads (do not track)
services/storage/storage/

# Large local assets (not tracked)
assetsReal/

# Internal augmentation artifacts (ignore if re-created)
.augment_*.txt
*.augment.log

# Local ops secrets (do not commit)
.ops/
frontend/_templates/tailwind-landing-page-template
